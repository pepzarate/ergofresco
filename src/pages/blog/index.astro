---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostGrid from "../../components/blog/PostGrid.astro";

const allPosts: CollectionEntry<"blog">[] = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
	title="Articles — ErgoFresco"
	description="Ergonomics and cooling gear reviews, guides, and tips for remote workers in warm climates."
>
	<section class="blog-index">
		<div class="container">
			<div class="page-header">
				<h1>Articles</h1>
				<p>
					Guides, reviews, and tips to keep you cool and comfortable
					at your desk.
				</p>
			</div>

			{
				allPosts.length === 0 ? (
					<div class="empty-state">
						<span>📝</span>
						<p>Articles coming soon. Check back shortly.</p>
					</div>
				) : (
					<PostGrid
						posts={allPosts}
						columns={3}
						featuredFirst={true}
					/>
				)
			}
		</div>
	</section>
</BaseLayout>

<style>
	.blog-index {
		padding: 4rem 0 6rem;
	}

	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.page-header {
		margin-bottom: 3rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border);
	}

	.page-header h1 {
		font-size: clamp(2rem, 5vw, 3rem);
		letter-spacing: -0.03em;
		margin-bottom: 0.5rem;
	}

	.page-header p {
		font-size: 1rem;
		color: var(--text-muted);
		margin: 0;
	}

	.empty-state {
		text-align: center;
		padding: 4rem 0;
		color: var(--text-muted);
	}

	.empty-state span {
		font-size: 2.5rem;
		display: block;
		margin-bottom: 1rem;
	}
</style>
