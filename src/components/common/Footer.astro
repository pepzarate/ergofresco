---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<a href="/" class="footer-logo">
				<img
					src="/logo.svg"
					alt="ErgoFresco logo"
					width="24"
					height="24"
				/>
				<span>ErgoFresco</span>
			</a>
			<p>Stay cool. Work better.</p>
		</div>

		<nav class="footer-nav">
			<div class="footer-col">
				<span class="footer-col-title">Content</span>
				<a href="/blog">All articles</a>
				<a href="/blog?category=cooling">Cooling</a>
				<a href="/blog?category=ergonomics">Ergonomics</a>
				<a href="/blog?category=reviews">Reviews</a>
			</div>
			<div class="footer-col">
				<span class="footer-col-title">Site</span>
				<a href="/about">About</a>
				<a href="/about#affiliate">Affiliate disclosure</a>
				<a href="/rss.xml">RSS feed</a>
			</div>
		</nav>
	</div>

	<div class="footer-bottom">
		<p>&copy; {year} ErgoFresco. All rights reserved.</p>
		<p>
			This site contains affiliate links. We may earn a commission at no
			extra cost to you. <a href="/about#affiliate">Learn more</a>.
		</p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		background: var(--bg);
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3rem 1.5rem 2rem;
		display: flex;
		gap: 3rem;
		justify-content: space-between;
		flex-wrap: wrap;
	}

	/* ─── Brand ───────────────────────────────────────────────── */
	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.footer-logo {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-family: "Fraunces", serif;
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--text);
		text-decoration: none;
		letter-spacing: -0.02em;
		transition: color 0.15s ease;
	}

	.footer-logo img {
		width: 24px;
		height: 24px;
		flex-shrink: 0;
	}

	.footer-logo:hover {
		color: var(--accent);
	}

	.footer-brand p {
		font-size: 0.82rem;
		color: var(--text-muted);
		margin: 0;
	}

	/* ─── Nav ─────────────────────────────────────────────────── */
	.footer-nav {
		display: flex;
		gap: 3rem;
		flex-wrap: wrap;
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.footer-col-title {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text);
		margin-bottom: 0.2rem;
	}

	.footer-col a {
		font-size: 0.875rem;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.footer-col a:hover {
		color: var(--accent);
	}

	/* ─── Bottom ──────────────────────────────────────────────── */
	.footer-bottom {
		max-width: 1100px;
		margin: 0 auto;
		padding: 1.25rem 1.5rem;
		border-top: 1px solid var(--border);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.footer-bottom p {
		font-size: 0.78rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.5;
	}

	.footer-bottom a {
		color: var(--accent);
		font-weight: 600;
	}

	.footer-bottom a:hover {
		color: var(--accent-dark);
	}

	@media (max-width: 640px) {
		.footer-inner {
			flex-direction: column;
			gap: 2rem;
		}

		.footer-bottom {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.5rem;
		}
	}
</style>
