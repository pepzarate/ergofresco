---
// No props needed
---

<section class="newsletter">
    <div class="newsletter-inner">
        <div class="newsletter-copy">
            <span class="newsletter-badge">📬 Free newsletter</span>
            <h2>Stay cool. Stay productive.</h2>
            <p>
                Get weekly tips on ergonomics and cooling gear for your home
                office. No spam, unsubscribe anytime.
            </p>
        </div>

        <form
            id="newsletter-form"
            method="POST"
            action="https://12c0100d.sibforms.com/serve/MUIFAEI-T_bDADiH_uj9j1QcCV-E4sW7cKETdTj3hqAICbqlzwvp2ltRp9OFxCSwTXIPw4sWV3XJxvonQ0GXfOSRts6ABE4ysso6Sb4w6Kn7aU28uho2QHg5GJByDPGwwACLgaSx4HTF_txbrzTv0GkMMnY73IjZ18i6fB1lixzSvWWD_fsy28B5TVxnc3bdm9eo15sxKbhMHkkjZQ=="
        >
            <div class="form-row">
                <input
                    type="email"
                    id="EMAIL"
                    name="EMAIL"
                    placeholder="your@email.com"
                    required
                    autocomplete="email"
                    aria-label="Your email address"
                />
                <button type="submit">Get free tips →</button>
            </div>

            <!-- Required hidden fields by Brevo -->
            <input
                type="text"
                name="email_address_check"
                value=""
                class="sr-only"
            />
            <input type="hidden" name="locale" value="en" />
            <input type="hidden" name="html_type" value="simple" />
        </form>
    </div>
</section>

<style>
    .newsletter {
        background: var(--bg-subtle);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 4rem 1.5rem;
    }

    .newsletter-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
    }

    .newsletter-badge {
        display: inline-block;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--accent);
        background: var(--accent-soft);
        border: 1px solid var(--accent);
        border-radius: 99px;
        padding: 0.25rem 0.75rem;
        margin-bottom: 1rem;
    }

    .newsletter-copy h2 {
        font-size: clamp(1.4rem, 3vw, 1.9rem);
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
        color: var(--text);
    }

    .newsletter-copy p {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin: 0;
    }

    .form-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    input[type="email"] {
        flex: 1;
        min-width: 0;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        font-family: inherit;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text);
        outline: none;
        transition: border-color 0.15s ease;
    }

    input[type="email"]::placeholder {
        color: var(--text-muted);
    }

    input[type="email"]:focus {
        border-color: var(--accent);
    }

    button[type="submit"] {
        padding: 0.75rem 1.5rem;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: inherit;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        white-space: nowrap;
        transition:
            background 0.15s ease,
            transform 0.1s ease;
    }

    button[type="submit"]:hover {
        background: var(--accent-dark);
        transform: translateY(-1px);
    }

    /* ─── Responsive ──────────────────────────────────────────── */
    @media (max-width: 768px) {
        .newsletter-inner {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
    }

    @media (max-width: 480px) {
        .form-row {
            flex-direction: column;
        }

        button[type="submit"] {
            width: 100%;
            text-align: center;
        }
    }
</style>
