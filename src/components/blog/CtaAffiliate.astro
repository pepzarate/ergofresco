---
interface Props {
    title?: string;
    description?: string;
    linkText?: string;
    linkUrl?: string;
}

const {
    title = "Ready to upgrade your home office?",
    description = "Browse our top-tested picks for ergonomic chairs, desk fans, and cooling gear — all selected for warm climate home offices.",
    linkText = "See all recommendations",
    linkUrl = "/blog",
} = Astro.props;
---

<div class="cta-affiliate">
    <div class="cta-affiliate__content">
        <h4 class="cta-affiliate__title">{title}</h4>
        <p class="cta-affiliate__description">{description}</p>
    </div>
    <a href={linkUrl} class="cta-affiliate__btn">
        {linkText} →
    </a>
</div>

<style>
    .cta-affiliate {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem;
        margin: 2.5rem 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        flex-wrap: wrap;
        transition: border-color 0.15s ease;
    }

    .cta-affiliate:hover {
        border-color: var(--accent);
    }

    .cta-affiliate__content {
        flex: 1;
        min-width: 200px;
    }

    .cta-affiliate__title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        margin: 0 0 0.35rem;
        line-height: 1.3;
    }

    .cta-affiliate__description {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.55;
        margin: 0;
    }

    .cta-affiliate__btn {
        display: inline-block;
        background: var(--accent);
        color: #fff;
        font-size: 0.875rem;
        font-weight: 600;
        padding: 0.65rem 1.35rem;
        border-radius: 8px;
        text-decoration: none;
        white-space: nowrap;
        flex-shrink: 0;
        transition:
            background 0.15s ease,
            transform 0.1s ease;
    }

    .cta-affiliate__btn:hover {
        background: var(--accent-dark);
        color: #fff;
        transform: translateY(-1px);
    }

    @media (max-width: 480px) {
        .cta-affiliate {
            flex-direction: column;
            align-items: flex-start;
        }

        .cta-affiliate__btn {
            width: 100%;
            text-align: center;
        }
    }
</style>
