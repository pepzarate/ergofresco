---
import type { Post } from "../../types/index";
import { formatDate } from "../../lib/utils";

interface Props {
    post: Post;
    variant?: "default" | "featured";
}

const { post, variant = "default" } = Astro.props;
const { title, description, pubDate, heroImage, category } = post.data;

const categoryLabel: Record<string, string> = {
    cooling: "Cooling",
    ergonomics: "Ergonomics",
    reviews: "Reviews",
};
---

<a
    href={`/blog/${post.id}/`}
    class:list={["post-card", `post-card--${variant}`]}
>
    {
        heroImage && (
            <div class="post-card__image">
                <img
                    src={heroImage.src}
                    alt={title}
                    width={variant === "featured" ? 800 : 400}
                    height={variant === "featured" ? 420 : 210}
                    loading="lazy"
                    decoding="async"
                />
            </div>
        )
    }
    <div class="post-card__body">
        <div class="post-card__meta">
            {
                category && (
                    <span class="post-card__category">
                        {categoryLabel[category] ?? category}
                    </span>
                )
            }
            <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        </div>
        <h2 class="post-card__title">{title}</h2>
        <p class="post-card__description">{description}</p>
        <span class="post-card__cta">Read article →</span>
    </div>
</a>

<style>
    .post-card {
        display: flex;
        flex-direction: column;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        text-decoration: none;
        color: var(--text);
        transition:
            border-color 0.15s ease,
            transform 0.15s ease;
    }

    .post-card:hover {
        border-color: var(--accent);
        transform: translateY(-2px);
        color: var(--text);
    }

    /* ─── Image ───────────────────────────────────────────────── */
    .post-card__image {
        width: 100%;
        overflow: hidden;
        aspect-ratio: 16 / 9;
    }

    .post-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .post-card:hover .post-card__image img {
        transform: scale(1.03);
    }

    /* ─── Body ────────────────────────────────────────────────── */
    .post-card__body {
        padding: 1.25rem 1.5rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
    }

    /* ─── Meta ────────────────────────────────────────────────── */
    .post-card__meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .post-card__category {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--accent);
        background: var(--accent-soft);
        padding: 2px 8px;
        border-radius: 99px;
        border: 1px solid var(--accent);
    }

    .post-card__meta time {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    /* ─── Title ───────────────────────────────────────────────── */
    .post-card__title {
        font-size: 1.1rem;
        line-height: 1.3;
        color: var(--text);
        transition: color 0.15s ease;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .post-card:hover .post-card__title {
        color: var(--accent);
    }

    /* ─── Description ─────────────────────────────────────────── */
    .post-card__description {
        font-size: 0.875rem;
        color: var(--text-muted);
        line-height: 1.55;
        margin: 0;
        flex: 1;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    /* ─── CTA ─────────────────────────────────────────────────── */
    .post-card__cta {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--accent);
        margin-top: 0.25rem;
        transition: color 0.15s ease;
    }

    .post-card:hover .post-card__cta {
        color: var(--accent-dark);
    }

    /* ─── Featured variant ────────────────────────────────────── */
    .post-card--featured .post-card__title {
        font-size: 1.4rem;
        -webkit-line-clamp: 3;
    }

    .post-card--featured .post-card__description {
        -webkit-line-clamp: 3;
    }
</style>
