---
interface Props {
    message?: string;
}

const {
    message = "Get our free weekly tips on staying cool and ergonomic while working from home.",
} = Astro.props;
---

<div class="cta-newsletter">
    <div class="cta-newsletter__content">
        <div class="cta-newsletter__icon">📬</div>
        <div class="cta-newsletter__text">
            <strong>Before you buy anything</strong>
            <p>{message}</p>
        </div>
    </div>
    <form
        class="cta-newsletter__form"
        method="POST"
        action="https://12c0100d.sibforms.com/serve/MUIFAEI-T_bDADiH_uj9j1QcCV-E4sW7cKETdTj3hqAICbqlzwvp2ltRp9OFxCSwTXIPw4sWV3XJxvonQ0GXfOSRts6ABE4ysso6Sb4w6Kn7aU28uho2QHg5GJByDPGwwACLgaSx4HTF_txbrzTv0GkMMnY73IjZ18i6fB1lixzSvWWD_fsy28B5TVxnc3bdm9eo15sxKbhMHkkjZQ=="
    >
        <input
            type="email"
            name="EMAIL"
            placeholder="your@email.com"
            required
            autocomplete="email"
            aria-label="Your email address"
        />
        <button type="submit">Get free tips →</button>
        <input
            type="text"
            name="email_address_check"
            value=""
            class="sr-only"
        />
        <input type="hidden" name="locale" value="en" />
        <input type="hidden" name="html_type" value="simple" />
    </form>
</div>

<style>
    .cta-newsletter {
        background: var(--bg-subtle);
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin: 2rem 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .cta-newsletter__content {
        display: flex;
        align-items: flex-start;
        gap: 0.875rem;
    }

    .cta-newsletter__icon {
        font-size: 1.4rem;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .cta-newsletter__text strong {
        display: block;
        font-size: 0.95rem;
        color: var(--text);
        margin-bottom: 0.2rem;
    }

    .cta-newsletter__text p {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
    }

    .cta-newsletter__form {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .cta-newsletter__form input[type="email"] {
        flex: 1;
        min-width: 0;
        padding: 0.6rem 0.875rem;
        font-size: 0.875rem;
        font-family: inherit;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 7px;
        color: var(--text);
        outline: none;
        transition: border-color 0.15s ease;
    }

    .cta-newsletter__form input[type="email"]::placeholder {
        color: var(--text-muted);
    }

    .cta-newsletter__form input[type="email"]:focus {
        border-color: var(--accent);
    }

    .cta-newsletter__form button {
        padding: 0.6rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 600;
        font-family: inherit;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: 7px;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.15s ease;
    }

    .cta-newsletter__form button:hover {
        background: var(--accent-dark);
    }

    @media (max-width: 480px) {
        .cta-newsletter__form {
            flex-direction: column;
        }

        .cta-newsletter__form button {
            width: 100%;
        }
    }
</style>
