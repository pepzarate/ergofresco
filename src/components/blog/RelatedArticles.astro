---
import type { Post } from "../../types/index";
import { formatDate } from "../../lib/utils";

interface Props {
    currentId: string;
    posts: Post[];
    maxPosts?: number;
}

const { currentId, posts, maxPosts = 3 } = Astro.props;

const related = posts.filter((p) => p.id !== currentId).slice(0, maxPosts);
---

{
    related.length > 0 && (
        <aside class="related-articles">
            <div class="related-articles__header">
                <h3>Continue reading...</h3>
                <a href="/blog" class="related-articles__all">
                    All articles →
                </a>
            </div>
            <div class="related-articles__grid">
                {related.map((post) => (
                    <a href={`/blog/${post.id}/`} class="related-card">
                        {post.data.heroImage && (
                            <div class="related-card__image">
                                <img
                                    src={post.data.heroImage.src}
                                    alt={post.data.title}
                                    width={300}
                                    height={160}
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                        )}
                        <div class="related-card__body">
                            {post.data.category && (
                                <span class="related-card__category">
                                    {post.data.category}
                                </span>
                            )}
                            <h4 class="related-card__title">
                                {post.data.title}
                            </h4>
                            <time
                                class="related-card__date"
                                datetime={post.data.pubDate.toISOString()}
                            >
                                {formatDate(post.data.pubDate)}
                            </time>
                        </div>
                    </a>
                ))}
            </div>
        </aside>
    )
}

<style>
    .related-articles {
        margin-top: 3rem;
        padding-top: 2.5rem;
        border-top: 1px solid var(--border);
    }

    .related-articles__header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 1.25rem;
        gap: 1rem;
    }

    .related-articles__header h3 {
        font-size: 1.2rem;
        letter-spacing: -0.02em;
        color: var(--text);
    }

    .related-articles__all {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--accent);
        text-decoration: none;
        white-space: nowrap;
        transition: color 0.15s ease;
    }

    .related-articles__all:hover {
        color: var(--accent-dark);
    }

    .related-articles__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    /* ─── Card ────────────────────────────────────────────────── */
    .related-card {
        display: flex;
        flex-direction: column;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        color: var(--text);
        transition:
            border-color 0.15s ease,
            transform 0.15s ease;
    }

    .related-card:hover {
        border-color: var(--accent);
        transform: translateY(-2px);
        color: var(--text);
    }

    .related-card__image {
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
    }

    .related-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .related-card:hover .related-card__image img {
        transform: scale(1.04);
    }

    .related-card__body {
        padding: 0.875rem 1rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        flex: 1;
    }

    .related-card__category {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--accent);
    }

    .related-card__title {
        font-size: 0.9rem;
        line-height: 1.35;
        color: var(--text);
        transition: color 0.15s ease;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .related-card:hover .related-card__title {
        color: var(--accent);
    }

    .related-card__date {
        font-size: 0.72rem;
        color: var(--text-muted);
        margin-top: auto;
    }

    @media (max-width: 768px) {
        .related-articles__grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 480px) {
        .related-articles__grid {
            grid-template-columns: 1fr;
        }
    }
</style>
