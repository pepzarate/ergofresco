---
import type { Product } from "../../types/index";

interface Props {
    products: Product[];
    title?: string;
}

const { products, title = "Product Comparison" } = Astro.props;

function renderStars(rating: number): { filled: boolean }[] {
    return Array.from({ length: 5 }, (_, i) => ({
        filled: i < Math.round(rating),
    }));
}
---

<div class="comparison-table">
    <h3 class="comparison-table__title">{title}</h3>

    <div class="comparison-table__wrapper">
        <table>
            <thead>
                <tr>
                    <th class="col-feature">Feature</th>
                    {
                        products.map((p) => (
                            <th class="col-product">
                                {p.badge && (
                                    <span class="th-badge">{p.badge}</span>
                                )}
                                <span class="th-name">{p.name}</span>
                                <span class="th-price">{p.price}</span>
                            </th>
                        ))
                    }
                </tr>
            </thead>
            <tbody>
                <tr class="row-rating">
                    <td class="label-cell">Rating</td>
                    {
                        products.map((p) => (
                            <td class="value-cell">
                                {p.rating ? (
                                    <div
                                        class="stars"
                                        aria-label={`${p.rating} out of 5`}
                                    >
                                        {renderStars(p.rating).map((s) => (
                                            <span
                                                class:list={[
                                                    "star",
                                                    {
                                                        "star--filled":
                                                            s.filled,
                                                    },
                                                ]}
                                                aria-hidden="true"
                                            >
                                                ★
                                            </span>
                                        ))}
                                        <span class="stars__value">
                                            {p.rating}/5
                                        </span>
                                    </div>
                                ) : (
                                    <span class="na">—</span>
                                )}
                            </td>
                        ))
                    }
                </tr>

                <tr>
                    <td class="label-cell">Description</td>
                    {
                        products.map((p) => (
                            <td class="value-cell value-cell--desc">
                                {p.description}
                            </td>
                        ))
                    }
                </tr>

                {
                    products.some((p) => p.pros && p.pros.length > 0) && (
                        <tr class="row-pros">
                            <td class="label-cell">Pros</td>
                            {products.map((p) => (
                                <td class="value-cell">
                                    {p.pros && p.pros.length > 0 ? (
                                        <ul class="mini-list mini-list--pros">
                                            {p.pros.map((pro) => (
                                                <li>{pro}</li>
                                            ))}
                                        </ul>
                                    ) : (
                                        <span class="na">—</span>
                                    )}
                                </td>
                            ))}
                        </tr>
                    )
                }

                {
                    products.some((p) => p.cons && p.cons.length > 0) && (
                        <tr class="row-cons">
                            <td class="label-cell">Cons</td>
                            {products.map((p) => (
                                <td class="value-cell">
                                    {p.cons && p.cons.length > 0 ? (
                                        <ul class="mini-list mini-list--cons">
                                            {p.cons.map((con) => (
                                                <li>{con}</li>
                                            ))}
                                        </ul>
                                    ) : (
                                        <span class="na">—</span>
                                    )}
                                </td>
                            ))}
                        </tr>
                    )
                }

                <tr class="row-cta">
                    <td class="label-cell">Buy</td>
                    {
                        products.map((p) => (
                            <td class="value-cell">
                                <a
                                    href={p.affiliateUrl}
                                    target="_blank"
                                    rel="nofollow sponsored noopener"
                                    class="cta-btn"
                                >
                                    Check price →
                                </a>
                            </td>
                        ))
                    }
                </tr>
            </tbody>
        </table>
    </div>
</div>

<style>
    .comparison-table {
        margin: 2.5rem 0;
    }

    .comparison-table__title {
        font-size: 1.3rem;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
        color: var(--text);
    }

    /* ─── Scroll wrapper ──────────────────────────────────────── */
    .comparison-table__wrapper {
        overflow-x: auto;
        border: 1px solid var(--border);
        border-radius: 14px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        min-width: 500px;
    }

    /* ─── Header ──────────────────────────────────────────────── */
    thead th {
        background: var(--bg-subtle);
        padding: 1rem 1.25rem;
        text-align: left;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
    }

    .col-feature {
        width: 130px;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-muted);
    }

    .col-product {
        display: table-cell;
    }

    .th-badge {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #fff;
        background: var(--accent);
        padding: 2px 8px;
        border-radius: 99px;
        margin-bottom: 6px;
    }

    .th-name {
        display: block;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1.3;
    }

    .th-price {
        display: block;
        font-size: 1rem;
        font-weight: 700;
        color: var(--accent);
        margin-top: 4px;
    }

    /* ─── Body ────────────────────────────────────────────────── */
    tbody tr {
        border-bottom: 1px solid var(--border);
    }

    tbody tr:last-child {
        border-bottom: none;
    }

    tbody tr:hover td {
        background: var(--bg-subtle);
    }

    .label-cell {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 0.875rem 1.25rem;
        vertical-align: top;
        white-space: nowrap;
        background: var(--bg-subtle);
        border-right: 1px solid var(--border);
    }

    .value-cell {
        padding: 0.875rem 1.25rem;
        font-size: 0.875rem;
        color: var(--text);
        vertical-align: top;
        border-right: 1px solid var(--border);
    }

    .value-cell:last-child {
        border-right: none;
    }

    .value-cell--desc {
        color: var(--text-muted);
        font-size: 0.82rem;
        line-height: 1.5;
    }

    /* ─── Stars ───────────────────────────────────────────────── */
    .stars {
        display: flex;
        align-items: center;
        gap: 2px;
    }

    .star {
        font-size: 0.95rem;
        color: var(--border);
        line-height: 1;
    }

    .star--filled {
        color: #f59e0b;
    }

    .stars__value {
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-left: 4px;
    }

    /* ─── Mini lists ──────────────────────────────────────────── */
    .mini-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .mini-list li {
        font-size: 0.8rem;
        line-height: 1.4;
        padding-left: 1.1rem;
        position: relative;
    }

    .mini-list--pros li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: #10b981;
        font-weight: 700;
    }

    .mini-list--cons li::before {
        content: "✗";
        position: absolute;
        left: 0;
        color: #ef4444;
        font-weight: 700;
    }

    /* ─── CTA ─────────────────────────────────────────────────── */
    .cta-btn {
        display: inline-block;
        background: var(--accent);
        color: #fff;
        font-size: 0.8rem;
        font-weight: 600;
        padding: 0.5rem 1rem;
        border-radius: 7px;
        text-decoration: none;
        white-space: nowrap;
        transition: background 0.15s ease;
    }

    .cta-btn:hover {
        background: var(--accent-dark);
        color: #fff;
    }

    .na {
        color: var(--text-muted);
        font-size: 0.85rem;
    }
</style>
