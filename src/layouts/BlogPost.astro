---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/common/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<BaseLayout
	title={title}
	description={description}
	image={heroImage}
	pubDate={pubDate}
	updatedDate={updatedDate}
	isArticle={true}
>
	<article class="article">
		<!-- ─── Hero Image ──────────────────────────────────────── -->
		{
			heroImage && (
				<div class="hero-image">
					<Image
						src={heroImage}
						alt={title}
						width={1200}
						height={600}
						loading="eager"
						quality={85}
					/>
				</div>
			)
		}

		<!-- ─── Article Header ─────────────────────────────────── -->
		<div class="container">
			<header class="article-header">
				<div class="article-meta">
					<FormattedDate date={pubDate} />
					{
						updatedDate && (
							<span class="updated">
								· Updated <FormattedDate date={updatedDate} />
							</span>
						)
					}
				</div>
				<h1>{title}</h1>
				<p class="article-description">{description}</p>
				<hr class="divider" />
			</header>

			<!-- ─── Affiliate Disclaimer ──────────────────────────── -->
			<aside class="affiliate-notice">
				<span class="notice-icon">🔗</span>
				<p>
					This article contains affiliate links. If you purchase
					through our links, we may earn a small commission at no
					extra cost to you.
					<a href="/about#affiliate">Learn more</a>.
				</p>
			</aside>

			<!-- ─── Article Body ──────────────────────────────────── -->
			<div class="prose">
				<slot />
			</div>

			<!-- ─── Article Footer ────────────────────────────────── -->
			<footer class="article-footer">
				<hr class="divider" />
				<div class="footer-nav">
					<a href="/blog" class="back-link">← Back to all articles</a>
				</div>
			</footer>
		</div>
	</article>
</BaseLayout>

<style>
	/* ─── Article wrapper ─────────────────────────────────────── */
	.article {
		padding-bottom: 6rem;
	}

	.container {
		max-width: 780px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	/* ─── Hero Image ──────────────────────────────────────────── */
	.hero-image {
		width: 100%;
		margin-bottom: 2.5rem;
	}

	.hero-image img {
		width: 100%;
		height: auto;
		max-height: 520px;
		object-fit: cover;
		object-position: center;
		border-radius: 0;
	}

	@media (min-width: 780px) {
		.hero-image {
			padding: 0 1.5rem;
			max-width: 1100px;
			margin: 2rem auto 2.5rem;
		}

		.hero-image img {
			border-radius: 16px;
		}
	}

	/* ─── Article Header ──────────────────────────────────────── */
	.article-header {
		padding: 2.5rem 0 0;
	}

	.article-meta {
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		gap: 0.25rem;
		flex-wrap: wrap;
	}

	.updated {
		color: var(--text-muted);
		font-weight: 500;
	}

	.article-header h1 {
		font-size: clamp(1.8rem, 5vw, 2.75rem);
		letter-spacing: -0.03em;
		line-height: 1.1;
		margin-bottom: 1rem;
		color: var(--text);
	}

	.article-description {
		font-size: 1.1rem;
		color: var(--text-muted);
		line-height: 1.6;
		margin: 0;
	}

	.divider {
		border: none;
		border-top: 1px solid var(--border);
		margin: 2rem 0;
	}

	/* ─── Affiliate Notice ────────────────────────────────────── */
	.affiliate-notice {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		background: var(--bg-subtle);
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		border-radius: 8px;
		padding: 0.875rem 1rem;
		margin-bottom: 2.5rem;
	}

	.notice-icon {
		font-size: 1rem;
		flex-shrink: 0;
		margin-top: 1px;
	}

	.affiliate-notice p {
		font-size: 0.82rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.5;
	}
</style>
